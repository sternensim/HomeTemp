# Home Assistant Docker Environment Configuration
# Copy this file to .env and customize for your setup

# Timezone (e.g., Europe/Berlin, America/New_York, Australia/Sydney)
TZ=Europe/Berlin

# Home Assistant Port
HA_PORT=8123

# ESPHome Port
ESPHOME_PORT=6052

# Portainer Port (optional container management)
PORTAINER_PORT=9000

# Docker network subnet (change only if conflicts with your network)
NETWORK_SUBNET=172.20.0.0/16
